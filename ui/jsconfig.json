{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "types/**/*.d.ts",
    "modules/comms/message-envelope.js",
    "modules/ipc/cognitive-memory-handlers.js",
    "modules/ipc/device-pairing-handlers.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "coverage"
  ]
}
